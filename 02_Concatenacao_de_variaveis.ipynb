   "source": [
    "# Entrada do usuário\n",
    "nome = input(\"Digite seu nome: \")\n",
    "\n",
    "# Concatenação simples\n",
    "print(\"Nome digitado: \", nome)\n",
    "\n",
    "# Formas de concatenação\n",
    "print(\"Olá \" + nome + \"!\")           # operador +\n",
    "print(f\"Olá {nome}!\")                # f-string\n",
    "print(\"Olá {}!\".format(nome))        # .format()"
   ]
